# ────────────────────────────────────────────────────────────────
#  Arylmera dashboard — environment template
#
#  Copy this file to `.env` and fill in real values. `.env` is
#  gitignored. Vite reads VITE_* on build (browser-visible) and
#  the rest server-side only — those are injected by the dev proxy
#  and NEVER reach the browser.
#
#  Leave a service blank to disable it; the dashboard hides or
#  greys-out anything missing config. The browser only ever calls
#  `/api/<svc>/...` paths — the dev server proxies them upstream
#  with the right auth header.
# ────────────────────────────────────────────────────────────────

# ─── TrueNAS Scale ─────────────────────────────────────────────
VITE_TRUENAS_URL=
TRUENAS_API_KEY=

# ─── Plex Media Server ─────────────────────────────────────────
VITE_PLEX_URL=
PLEX_TOKEN=

# ─── *arr stack (Sonarr / Radarr / Lidarr / Prowlarr) ──────────
VITE_SONARR_URL=
SONARR_API_KEY=

VITE_RADARR_URL=
RADARR_API_KEY=

VITE_LIDARR_URL=
LIDARR_API_KEY=

VITE_PROWLARR_URL=
PROWLARR_API_KEY=

# ─── Tautulli (Plex stats) ─────────────────────────────────────
VITE_TAUTULLI_URL=
TAUTULLI_API_KEY=

# ─── Overseerr / Seerr ─────────────────────────────────────────
VITE_SEERR_URL=
SEERR_API_KEY=

# ─── Pi-hole v6 ────────────────────────────────────────────────
# NOTE: Pi-hole's auth flow requires the key to be POST'd by the
# browser to obtain a session SID, so this key is browser-visible.
VITE_PIHOLE_URL=
VITE_PIHOLE_KEY=

# ─── Speedtest Tracker ─────────────────────────────────────────
VITE_SPEEDTEST_URL=
SPEEDTEST_API_KEY=

# ─── Audiobookshelf ────────────────────────────────────────────
VITE_AUDIOBOOKSHELF_URL=
AUDIOBOOKSHELF_API_KEY=

# ─── qBittorrent (cookie auth — user/pass) ────────────────────
VITE_QBITTORRENT_URL=
QBITTORRENT_USER=
QBITTORRENT_PASS=

# ─── Qui (qBittorrent dashboard) ──────────────────────────────
# X-API-Key auth. Generate the key in Qui → Settings → API Keys.
# `useQui` aggregates speeds + active torrent counts across every
# qBit instance configured inside Qui (/api/instances).
VITE_QUI_URL=
QUI_API_KEY=

# ─── Glances (no auth) ─────────────────────────────────────────
VITE_GLANCES_URL=

# ─── Beszel (basic auth) ───────────────────────────────────────
VITE_BESZEL_URL=
BESZEL_USER=
BESZEL_PASS=

# ─── NextCloud (basic auth) ────────────────────────────────────
VITE_NEXTCLOUD_URL=
NEXTCLOUD_USER=
NEXTCLOUD_PASS=

# ─── Arcane (docker manager) ───────────────────────────────────
VITE_ARCANE_URL=
ARCANE_API_KEY=

# ─── Tugtainer (container update tracker) ──────────────────────
# Used by the "container updates" digest on Home.
# Set `ENABLE_PUBLIC_API=true` on the Tugtainer container — the
# dashboard reads `/api/public/summary` and needs no token.
VITE_TUGTAINER_URL=

# ─── Calendar / Tasks (iCloud CalDAV) ──────────────────────────
# Server-side only — NOT VITE_*. Secrets must not reach the bundle.
# Apple ID + an *app-specific password* from appleid.apple.com
# (regular password is rejected when 2FA is on).
#
# Discovery is automatic; just give the displayname of the calendar
# and Reminders list you want surfaced on Home.
ICLOUD_USER=
ICLOUD_APP_PASSWORD=
# Calendar displayname. Use "*" or "all" to merge every iCloud
# calendar; or a comma-separated list ("Home,Work") to pick a few.
ICLOUD_CALENDAR=*
# Reminders list displayname. Use "*"/"all" to merge every list,
# or comma-separated names ("Rappels,Courses").
ICLOUD_REMINDERS=*

# ─── Nginx Proxy Manager ───────────────────────────────────────
# Admin UI URL (also linked from the Network page header).
# NPM_IDENTITY / NPM_SECRET are server-side only — exchanged for a
# bearer token via POST /api/tokens, cached in memory.
VITE_NPM_URL=
NPM_IDENTITY=
NPM_SECRET=

# ─── ASUS router (Asuswrt) ─────────────────────────────────────
# SSH backend (ssh2 npm lib). Use either password OR key auth:
#   - Password: set ASUS_PASSWORD (router admin password).
#   - Key: set ASUS_SSH_KEY to an absolute path to the private key.
#
# Enable SSH in router admin: Administration > System >
# Enable SSH = LAN only. Username is case-sensitive (usually "Admin").
VITE_ASUS_URL=
ASUS_SSH_HOST=
ASUS_SSH_PORT=1024
ASUS_USERNAME=Admin
ASUS_PASSWORD=
ASUS_SSH_KEY=

# AiMesh node (optional). All blank fields fall back to the main
# router credentials above. Set ASUS_NODE_SSH_HOST to enable.
ASUS_NODE_SSH_HOST=
ASUS_NODE_SSH_PORT=
ASUS_NODE_USERNAME=
ASUS_NODE_PASSWORD=
ASUS_NODE_SSH_KEY=

# ─── Homey Pro (cloud OAuth2) ──────────────────────────────────
# Create an OAuth2 app at https://tools.developer.homey.app/
# Callback URL must match HOMEY_REDIRECT_URI exactly.
# Authorize once by visiting /api/homey/oauth/login in your browser.
HOMEY_ID=
HOMEY_CLIENT_ID=
HOMEY_CLIENT_SECRET=
HOMEY_REDIRECT_URI=http://localhost:5173/api/homey/oauth/callback
HOMEY_SCOPE=

# ─── Spotify (Authorization Code OAuth2) ─────────────────────────
# Register an app at https://developer.spotify.com/dashboard
# Add the redirect URI exactly as below to the app settings.
# Authorize once by visiting /api/spotify/oauth/login.
# Premium account required for playback control.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=https://127.0.0.1:5173/api/spotify/oauth/callback

# Spotify requires HTTPS for redirect URIs and rejects `localhost` as a
# host. Vite is configured with @vitejs/plugin-basic-ssl so dev runs over
# HTTPS automatically — open https://127.0.0.1:5173 (accept the self-signed
# cert warning once). To disable HTTPS in dev, set DEV_HTTPS=false (then use
# the http://127.0.0.1 loopback exception instead).

# ─── Sonos LAN control (no cloud, no OAuth) ──────────────────────
# Speakers are discovered via SSDP (multicast) on the local network.
# If your network blocks multicast, set SONOS_HOSTS to a comma-separated
# list of speaker IPs and the dashboard will skip discovery.
# Example: SONOS_HOSTS=192.168.1.42,192.168.1.43
SONOS_HOSTS=

# Optional: your Spotify-on-Sonos account serial (the `sn=` query param
# in Sonos's Spotify URIs). Auto-discovered from existing Sonos favorites
# on first run. Override only if discovery picks the wrong account.
SONOS_SPOTIFY_SN=
